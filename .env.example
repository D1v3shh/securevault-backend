# ====================================================
# SecureVault - Environment Configuration Template
# Copy this file to .env and fill in the values
# ====================================================

# Application
NODE_ENV=development
APP_NAME=SecureVault
APP_PORT=3000
APP_HOST=0.0.0.0
API_PREFIX=api/v1
APP_CORS_ORIGINS=http://localhost:3000

# Database - MongoDB
MONGODB_URI=mongodb://user:password@localhost:27017/securevault?authSource=admin
MONGODB_DB_NAME=securevault

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=sv:

# JWT (MUST be changed in production - load from Vault)
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRATION=7d

# HashiCorp Vault
VAULT_ENABLED=true
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
VAULT_MOUNT_PATH=secret
VAULT_SECRETS_PATH=securevault
VAULT_TRANSIT_ENGINE=transit
VAULT_RETRY_ATTEMPTS=3
VAULT_RETRY_DELAY_MS=1000

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage/uploads
STORAGE_TEMP_PATH=./storage/temp
STORAGE_MAX_FILE_SIZE=104857600

# Encryption
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY_LENGTH=32
ENCRYPTION_IV_LENGTH=16
ENCRYPTION_AUTH_TAG_LENGTH=16

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_TTL=60
RATE_LIMIT_AUTH_MAX=10

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Super Admin Seed
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=
SEED_SUPER_ADMIN_FIRST_NAME=
SEED_SUPER_ADMIN_LAST_NAME=

# BullMQ
BULL_QUEUE_PREFIX=sv-queue
